# Copy to ".env" and fill in locally. Never commit ".env" (it is gitignored).
#
# Sensitive values (API keys, JWT secrets, DB URLs, cloud credentials, deploy tokens)
# must live only in environment variables, a local .env, or a secret manager — not in Git.

# --- Data stores ---
ES_URL=http://127.0.0.1:9200
DATABASE_URL=
REDIS_URL=redis://127.0.0.1:6379/0

# --- Auth (required in production) ---
JWT_SECRET=
# Optional: set true only for ephemeral local dev with a short test secret
# ALLOW_INSECURE_DEFAULT_JWT=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:3000

# --- Third-party APIs (optional) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
TAVILY_API_KEY=
YOUTUBE_API_KEY=
